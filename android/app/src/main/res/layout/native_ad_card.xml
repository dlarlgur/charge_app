<?xml version="1.0" encoding="utf-8"?>
<!--
  Native ad — 앱 카드(GasStationCard / EvStationCard) 와 동일한 시각 스타일.
  한 줄 카드: [icon] [headline+body] [CTA] (오른쪽). KakaoTalk 채팅 광고와 동일 구조.

  AdMob 가이드 준수:
   - NativeAdView 가 root.
   - headlineView / iconView / bodyView / callToActionView 는 setNativeAd 호출
     전에 NativeAdView 에 setter 로 등록 + 텍스트 바인딩 후 setNativeAd 호출.
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ad_card_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 아이콘 (브랜드 로고 자리) -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/ad_logo_bg">
                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="centerInside"
                    android:padding="6dp"
                    android:contentDescription="@null" />
            </FrameLayout>

            <!-- 가운데: headline + body -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <!-- AD 라벨 + headline 한 줄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AD"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:textColor="@color/ad_label_text"
                        android:background="@drawable/ad_label_bg"
                        android:paddingStart="5dp"
                        android:paddingEnd="5dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:layout_marginEnd="6dp"
                        android:includeFontPadding="false" />
                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ad_text_primary"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <TextView
                    android:id="@+id/ad_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textSize="11sp"
                    android:textColor="@color/ad_text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- 오른쪽: CTA 버튼 (pill) -->
            <Button
                android:id="@+id/ad_call_to_action"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFFFF"
                android:textAllCaps="false"
                android:background="@drawable/ad_cta_bg"
                android:stateListAnimator="@null" />
        </LinearLayout>
    </FrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
