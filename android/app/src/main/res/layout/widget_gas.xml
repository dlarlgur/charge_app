<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/gas_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_widget_card"
        android:elevation="6dp"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_widget_mark_gas"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="즐겨찾기 주유소"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"/>
            <ImageView
                android:id="@+id/gas_refresh"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:padding="6dp"
                android:src="@drawable/ic_widget_refresh"
                android:layout_marginEnd="2dp"
                android:contentDescription="새로고침"/>
            <ImageView
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:src="@drawable/ic_live_dot"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"/>
            <TextView
                android:id="@+id/gas_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_mute_2"
                android:fontFamily="@font/pretendard_bold"
                android:fontFeatureSettings="tnum"
                android:text="--:--"/>
        </LinearLayout>

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/gas_row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_best_gas">

            <TextView
                android:id="@+id/gas_brand1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:background="@drawable/bg_badge_hd"
                android:text="HD"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/gas_name1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.02"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="HD현대오일뱅크 효진주유소"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">
                    <TextView
                        android:id="@+id/gas_pill1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_neutral"
                        android:textSize="10sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="셀프"/>
                    <TextView
                        android:id="@+id/gas_sub1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="휘발유"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginStart="10dp"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/gas_price1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.04"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"
                    android:text="1,712"/>
                <TextView
                    android:id="@+id/gas_unit1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_muted"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingBottom="2dp"
                    android:paddingStart="1dp"
                    android:text="원"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/gas_row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal">

            <TextView
                android:id="@+id/gas_brand2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:background="@drawable/bg_badge_soil"
                android:text="S"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/gas_name2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.02"
                    android:singleLine="true"
                    android:ellipsize="end"
                    android:text="만남이엔지 두꺼비"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">
                    <TextView
                        android:id="@+id/gas_pill2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_neutral"
                        android:textSize="10sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="일반"/>
                    <TextView
                        android:id="@+id/gas_sub2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"
                        android:text="휘발유"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginStart="10dp"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/gas_price2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.04"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"
                    android:text="1,734"/>
                <TextView
                    android:id="@+id/gas_unit2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_muted"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingBottom="2dp"
                    android:paddingStart="1dp"
                    android:text="원"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3 (resize 시 노출) -->
        <LinearLayout
            android:id="@+id/gas_row3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal"
            android:visibility="gone">

            <TextView
                android:id="@+id/gas_brand3"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:background="@drawable/bg_badge_default"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/gas_name3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.02"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">
                    <TextView
                        android:id="@+id/gas_pill3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_neutral"
                        android:textSize="10sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="셀프"/>
                    <TextView
                        android:id="@+id/gas_sub3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginStart="10dp"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/gas_price3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.04"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"/>
                <TextView
                    android:id="@+id/gas_unit3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_muted"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingBottom="2dp"
                    android:paddingStart="1dp"
                    android:text="원"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 4 (resize 시 노출) -->
        <LinearLayout
            android:id="@+id/gas_row4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal"
            android:visibility="gone">

            <TextView
                android:id="@+id/gas_brand4"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:background="@drawable/bg_badge_default"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView
                    android:id="@+id/gas_name4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.02"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">
                    <TextView
                        android:id="@+id/gas_pill4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="1dp"
                        android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_neutral"
                        android:textSize="10sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="셀프"/>
                    <TextView
                        android:id="@+id/gas_sub4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginStart="10dp"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/gas_price4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:letterSpacing="-0.04"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"/>
                <TextView
                    android:id="@+id/gas_unit4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_muted"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingBottom="2dp"
                    android:paddingStart="1dp"
                    android:text="원"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
