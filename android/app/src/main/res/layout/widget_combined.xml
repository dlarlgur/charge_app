<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/combined_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_widget_card"
        android:elevation="6dp"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/ic_widget_mark_combined"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="기름반 전기반"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"/>
            <ImageView
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:src="@drawable/ic_live_dot"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"/>
            <TextView
                android:id="@+id/combined_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_mute_2"
                android:fontFamily="@font/pretendard_bold"
                android:fontFeatureSettings="tnum"
                android:text="--:--"/>
        </LinearLayout>

        <!-- GAS SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <ImageView
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_badge_gs"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="주유 · 즐겨찾기"
                android:textSize="11sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="0.04"/>
        </LinearLayout>

        <!-- Gas Row 1 -->
        <LinearLayout
            android:id="@+id/cg_row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_best_gas">

            <TextView
                android:id="@+id/cg_brand1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:background="@drawable/bg_badge_default"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/cg_name1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/widget_ink"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:singleLine="true"
                        android:ellipsize="end"/>
                    <ImageView
                        android:id="@+id/cg_star1"
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/ic_star_filled"
                        android:contentDescription="@null"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/cg_pill1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp" android:paddingEnd="6dp"
                        android:paddingTop="1dp" android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_neutral"
                        android:textSize="10sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="셀프"/>
                    <TextView
                        android:id="@+id/cg_sub1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginStart="10dp"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/cg_price1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"/>
                <TextView
                    android:id="@+id/cg_unit1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_muted"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingBottom="2dp"
                    android:paddingStart="1dp"
                    android:text="원"/>
            </LinearLayout>
        </LinearLayout>


        <!-- Gas Row 2 -->
        <LinearLayout
            android:id="@+id/cg_row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal">

            <TextView
                android:id="@+id/cg_brand2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:background="@drawable/bg_badge_default"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/cg_name2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/widget_ink"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:singleLine="true"
                        android:ellipsize="end"/>
                    <ImageView
                        android:id="@+id/cg_star2"
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/ic_star_filled"
                        android:contentDescription="@null"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/cg_pill2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp" android:paddingEnd="6dp"
                        android:paddingTop="1dp" android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_neutral"
                        android:textSize="10sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="셀프"/>
                    <TextView
                        android:id="@+id/cg_sub2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom"
                android:layout_marginStart="10dp"
                android:baselineAligned="false">
                <TextView
                    android:id="@+id/cg_price2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/widget_ink"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"/>
                <TextView
                    android:id="@+id/cg_unit2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_muted"
                    android:fontFamily="@font/pretendard_bold"
                    android:paddingBottom="2dp"
                    android:paddingStart="1dp"
                    android:text="원"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@color/widget_line_soft"
            android:contentDescription="@null"/>

        <!-- EV SECTION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">
            <ImageView
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:background="@drawable/bg_badge_ev_slow"
                android:layout_marginEnd="6dp"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="충전 · 잔여 자리"
                android:textSize="11sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="0.04"/>
        </LinearLayout>

        <!-- EV Row 1 -->
        <LinearLayout
            android:id="@+id/ce_row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_best_ev">

            <TextView
                android:id="@+id/ce_brand1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:text="EV"
                android:background="@drawable/bg_badge_ev_slow"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/ce_name1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/widget_ink"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:singleLine="true"
                        android:ellipsize="end"/>
                    <ImageView
                        android:id="@+id/ce_star1"
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/ic_star_filled"
                        android:contentDescription="@null"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/ce_pill1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp" android:paddingEnd="6dp"
                        android:paddingTop="1dp" android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_speed_slow"
                        android:textSize="10sp"
                        android:textColor="@color/widget_blue_text"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="완속"/>
                    <TextView
                        android:id="@+id/ce_sub1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <TextView
                        android:id="@+id/ce_avail1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_green"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/widget_mute_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:paddingBottom="1dp"
                        android:text="/"/>
                    <TextView
                        android:id="@+id/ce_total1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/ce_status1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:paddingStart="7dp" android:paddingEnd="7dp"
                    android:paddingTop="2dp" android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:background="@drawable/bg_pill_status_avail"
                    android:textColor="@color/widget_green_text"
                    android:text="여유 가용"/>
            </LinearLayout>
        </LinearLayout>


        <!-- EV Row 2 -->
        <LinearLayout
            android:id="@+id/ce_row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal">

            <TextView
                android:id="@+id/ce_brand2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:text="EV"
                android:background="@drawable/bg_badge_ev_slow"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/ce_name2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/widget_ink"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:singleLine="true"
                        android:ellipsize="end"/>
                    <ImageView
                        android:id="@+id/ce_star2"
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:layout_marginStart="5dp"
                        android:src="@drawable/ic_star_filled"
                        android:contentDescription="@null"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/ce_pill2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="6dp" android:paddingEnd="6dp"
                        android:paddingTop="1dp" android:paddingBottom="1dp"
                        android:background="@drawable/bg_pill_speed_slow"
                        android:textSize="10sp"
                        android:textColor="@color/widget_blue_text"
                        android:fontFamily="@font/pretendard_bold"
                        android:text="완속"/>
                    <TextView
                        android:id="@+id/ce_sub2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="5dp"
                        android:textSize="10sp"
                        android:textColor="@color/widget_muted"
                        android:fontFamily="@font/pretendard_semibold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <TextView
                        android:id="@+id/ce_avail2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_green"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/widget_mute_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:paddingBottom="1dp"
                        android:text="/"/>
                    <TextView
                        android:id="@+id/ce_total2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/ce_status2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:paddingStart="7dp" android:paddingEnd="7dp"
                    android:paddingTop="2dp" android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:background="@drawable/bg_pill_status_avail"
                    android:textColor="@color/widget_green_text"
                    android:text="여유 가용"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
