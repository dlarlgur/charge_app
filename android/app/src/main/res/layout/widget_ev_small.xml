<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ev_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_widget_card_dense"
        android:elevation="6dp"
        android:padding="14dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_widget_mark_ev"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="충전 가용"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"/>
            <ImageView
                android:id="@+id/ev_small_refresh"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:padding="6dp"
                android:src="@drawable/ic_widget_refresh"
                android:contentDescription="새로고침"/>
        </LinearLayout>

        <TextView
            android:id="@+id/ev_small_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:ellipsize="end"
            android:textSize="13sp"
            android:textColor="@color/widget_ink"
            android:fontFamily="@font/pretendard_extrabold"
            android:lineSpacingMultiplier="1.1"
            android:text="동천자이아파트4"/>

        <TextView
            android:id="@+id/ev_small_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textSize="10sp"
            android:textColor="@color/widget_muted"
            android:fontFamily="@font/pretendard_bold"
            android:text="완속 7kW"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/ev_small_avail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textColor="@color/widget_green"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:fontFeatureSettings="tnum"
                android:includeFontPadding="false"
                android:text="3"/>
            <TextView
                android:id="@+id/ev_small_total_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="3dp"
                android:textSize="11sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_bold"
                android:text="/ 6 자리"/>
        </LinearLayout>

        <TextView
            android:id="@+id/ev_small_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:paddingStart="5dp"
            android:paddingEnd="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/bg_pill_status_avail"
            android:textSize="10sp"
            android:textColor="@color/widget_green_text"
            android:fontFamily="@font/pretendard_extrabold"
            android:text="여유 가용"/>

    </LinearLayout>
</FrameLayout>
