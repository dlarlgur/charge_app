<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ev_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="14dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="즐겨찾기 충전소"
            android:textSize="12sp"
            android:textColor="#111827"
            android:textStyle="bold"
            android:letterSpacing="-0.01" />
        <TextView
            android:id="@+id/ev_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="실시간"
            android:textSize="10sp"
            android:textColor="#9CA3AF" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/ev_row1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/ev_icon1"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="EV"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/badge_ev_ok"
            android:letterSpacing="-0.02" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="11dp"
            android:paddingRight="8dp">
            <TextView
                android:id="@+id/ev_name1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="즐겨찾기 충전소"
                android:textSize="13sp"
                android:textColor="#111827"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:letterSpacing="-0.02" />
            <TextView
                android:id="@+id/ev_type1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="급속 100kW"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="2dp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/ev_status1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textColor="#1D9E75"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="-0.03" />
            <TextView
                android:id="@+id/ev_total1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/3"
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:paddingLeft="1dp"
                android:paddingBottom="1dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:background="#F1F5F9"
        android:scaleType="fitXY" />

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/ev_row2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/ev_icon2"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:gravity="center"
            android:text="EV"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/badge_ev_busy"
            android:letterSpacing="-0.02" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingLeft="11dp"
            android:paddingRight="8dp">
            <TextView
                android:id="@+id/ev_name2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="앱에서 설정하기"
                android:textSize="13sp"
                android:textColor="#111827"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:letterSpacing="-0.02" />
            <TextView
                android:id="@+id/ev_type2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="완속"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="2dp" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:baselineAligned="false">
            <TextView
                android:id="@+id/ev_status2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="대기중"
                android:textColor="#EF9F27"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />
            <TextView
                android:id="@+id/ev_total2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#9CA3AF"
                android:textSize="11sp"
                android:paddingLeft="1dp"
                android:paddingBottom="1dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
