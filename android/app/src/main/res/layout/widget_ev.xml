<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚡ 충전소 현황"
            android:textSize="11sp"
            android:textColor="#999999"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/ev_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="#BBBBBB" />
    </LinearLayout>

    <!-- Row 1 -->
    <LinearLayout
        android:id="@+id/ev_row1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <TextView
            android:id="@+id/ev_icon1"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="⚡"
            android:textSize="13sp"
            android:background="#E1F5EE" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">
            <TextView
                android:id="@+id/ev_name1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#1a1a1a"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/ev_type1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#999999"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
        <TextView
            android:id="@+id/ev_status1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F5F5F5" />

    <!-- Row 2 -->
    <LinearLayout
        android:id="@+id/ev_row2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <TextView
            android:id="@+id/ev_icon2"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="⚡"
            android:textSize="13sp"
            android:background="#FAEEDA" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">
            <TextView
                android:id="@+id/ev_name2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#1a1a1a"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/ev_type2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#999999"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
        <TextView
            android:id="@+id/ev_status2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F5F5F5" />

    <!-- Row 3 -->
    <LinearLayout
        android:id="@+id/ev_row3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp"
        android:paddingBottom="2dp">
        <TextView
            android:id="@+id/ev_icon3"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="⚡"
            android:textSize="13sp"
            android:background="#FCEBEB" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="4dp">
            <TextView
                android:id="@+id/ev_name3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#1a1a1a"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/ev_type3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#999999"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
        <TextView
            android:id="@+id/ev_status3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:id="@+id/ev_footer"
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:text=""
        android:textSize="10sp"
        android:textColor="#BBBBBB"
        android:gravity="end|center_vertical" />

</LinearLayout>
