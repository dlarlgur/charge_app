<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ev_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp">

    <ImageView
        android:id="@+id/ev_widget_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null"
        android:src="@drawable/bg_widget_card" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:elevation="6dp"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_widget_mark_ev"
                android:contentDescription="@null"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="즐겨찾기 충전소"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"/>
            <ImageView
                android:id="@+id/ev_refresh"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:padding="11dp"
                android:src="@drawable/ic_widget_refresh"
                android:contentDescription="새로고침"/>
            <ProgressBar
                android:id="@+id/ev_progress"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:indeterminate="true"
                android:layout_marginEnd="4dp"
                android:visibility="gone"/>
            <ImageView
                android:id="@+id/ev_live_dot"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:src="@drawable/ic_live_dot"
                android:layout_marginEnd="4dp"
                android:contentDescription="@null"/>
            <TextView
                android:id="@+id/ev_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/widget_mute_2"
                android:fontFamily="@font/pretendard_bold"
                android:fontFeatureSettings="tnum"
                android:text="--:--"/>
        </LinearLayout>

        <!-- Row 1 -->
        <LinearLayout
            android:id="@+id/ev_row1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_best_ev">

            <TextView
                android:id="@+id/ev_brand1"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:text="EV"
                android:background="@drawable/bg_badge_ev_slow"/>

            <TextView
                android:id="@+id/ev_name1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="동천자이아파트4"/>
            <TextView
                android:id="@+id/ev_pill1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:background="@drawable/bg_pill_speed_slow"
                android:textSize="10sp"
                android:textColor="@color/widget_blue_text"
                android:fontFamily="@font/pretendard_bold"
                android:text="완속"/>
            <TextView
                android:id="@+id/ev_sub1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="10sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_semibold"
                android:text="7kW"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <TextView
                        android:id="@+id/ev_avail1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_green"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:letterSpacing="-0.04"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"
                        android:text="3"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/widget_mute_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:paddingBottom="1dp"
                        android:text="/"/>
                    <TextView
                        android:id="@+id/ev_total1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"
                        android:text="6"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/ev_status1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:background="@drawable/bg_pill_status_avail"
                    android:textColor="@color/widget_green_text"
                    android:text="여유 가용"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:id="@+id/ev_row2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal">

            <TextView
                android:id="@+id/ev_brand2"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:text="EV"
                android:background="@drawable/bg_badge_ev_fast"/>

            <TextView
                android:id="@+id/ev_name2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="동자 2순위 급속"/>
            <TextView
                android:id="@+id/ev_pill2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:background="@drawable/bg_pill_speed_fast"
                android:textSize="10sp"
                android:textColor="@color/widget_green_text"
                android:fontFamily="@font/pretendard_bold"
                android:text="급속"/>
            <TextView
                android:id="@+id/ev_sub2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="10sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_semibold"
                android:text="100kW"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <TextView
                        android:id="@+id/ev_avail2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_red"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:letterSpacing="-0.04"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"
                        android:text="0"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/widget_mute_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:paddingBottom="1dp"
                        android:text="/"/>
                    <TextView
                        android:id="@+id/ev_total2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"
                        android:text="2"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/ev_status2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:background="@drawable/bg_pill_status_busy"
                    android:textColor="@color/widget_amber_text"
                    android:text="충전 중"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3 (resize 시 노출) -->
        <LinearLayout
            android:id="@+id/ev_row3"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal"
            android:visibility="gone">

            <TextView
                android:id="@+id/ev_brand3"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:text="EV"
                android:background="@drawable/bg_badge_ev_slow"/>

            <TextView
                android:id="@+id/ev_name3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"
                android:singleLine="true"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/ev_pill3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:background="@drawable/bg_pill_speed_slow"
                android:textSize="10sp"
                android:textColor="@color/widget_blue_text"
                android:fontFamily="@font/pretendard_bold"
                android:text="완속"/>
            <TextView
                android:id="@+id/ev_sub3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="10sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_semibold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <TextView
                        android:id="@+id/ev_avail3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_green"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:letterSpacing="-0.04"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/widget_mute_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:paddingBottom="1dp"
                        android:text="/"/>
                    <TextView
                        android:id="@+id/ev_total3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/ev_status3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:background="@drawable/bg_pill_status_avail"
                    android:textColor="@color/widget_green_text"
                    android:text="여유 가용"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Row 4 (resize 시 노출) -->
        <LinearLayout
            android:id="@+id/ev_row4"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="6dp"
            android:background="@drawable/bg_row_normal"
            android:visibility="gone">

            <TextView
                android:id="@+id/ev_brand4"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.04"
                android:text="EV"
                android:background="@drawable/bg_badge_ev_slow"/>

            <TextView
                android:id="@+id/ev_name4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="13sp"
                android:textColor="@color/widget_ink"
                android:fontFamily="@font/pretendard_extrabold"
                android:letterSpacing="-0.02"
                android:singleLine="true"
                android:ellipsize="end"/>
            <TextView
                android:id="@+id/ev_pill4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:background="@drawable/bg_pill_speed_slow"
                android:textSize="10sp"
                android:textColor="@color/widget_blue_text"
                android:fontFamily="@font/pretendard_bold"
                android:text="완속"/>
            <TextView
                android:id="@+id/ev_sub4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:textSize="10sp"
                android:textColor="@color/widget_muted"
                android:fontFamily="@font/pretendard_semibold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end"
                android:layout_marginStart="10dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">
                    <TextView
                        android:id="@+id/ev_avail4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_green"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:letterSpacing="-0.04"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/widget_mute_2"
                        android:fontFamily="@font/pretendard_bold"
                        android:paddingStart="2dp"
                        android:paddingEnd="2dp"
                        android:paddingBottom="1dp"
                        android:text="/"/>
                    <TextView
                        android:id="@+id/ev_total4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/widget_ink_2"
                        android:fontFamily="@font/pretendard_extrabold"
                        android:fontFeatureSettings="tnum"
                        android:includeFontPadding="false"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/ev_status4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="10sp"
                    android:fontFamily="@font/pretendard_extrabold"
                    android:background="@drawable/bg_pill_status_avail"
                    android:textColor="@color/widget_green_text"
                    android:text="여유 가용"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
