<?xml version="1.0" encoding="utf-8"?>
<!--
  Top 배너 광고 — 강조형. 큰 이미지(media) + 헤드라인·본문 + CTA.
  KakaoTalk '지금' 탭 상단 배너처럼 prominent 한 자리.
  height: ~108dp.
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ad_card_bg"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 큰 이미지 영역 80x80 — 강조형 시각 -->
            <ImageView
                android:id="@+id/ad_icon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:background="@drawable/ad_logo_bg"
                android:contentDescription="@null" />

            <!-- 가운데 + 오른쪽: headline / body / CTA pill -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <!-- AD 라벨 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AD"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:textColor="@color/ad_label_text"
                    android:background="@drawable/ad_label_bg"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:layout_marginBottom="4dp"
                    android:includeFontPadding="false" />

                <!-- Headline -->
                <TextView
                    android:id="@+id/ad_headline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/ad_text_primary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Body -->
                <TextView
                    android:id="@+id/ad_body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="11.5sp"
                    android:textColor="@color/ad_text_secondary"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <!-- CTA pill — 우측 정렬 작은 버튼 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="end"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/ad_call_to_action"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFFFF"
                        android:textAllCaps="false"
                        android:background="@drawable/ad_cta_bg"
                        android:stateListAnimator="@null" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
