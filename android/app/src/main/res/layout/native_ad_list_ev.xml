<?xml version="1.0" encoding="utf-8"?>
<!--
  EV 탭 인-피드 광고 — EvStationCard 와 동일한 시각.
  좌측 4dp 컬러 스트립 + 동일한 카드 구조. 스트립 색은 광고 표식용 brand blue.
-->
<com.google.android.gms.ads.nativead.NativeAdView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/ad_card_bg"
        android:clipChildren="true">

        <!-- 좌측 4dp 스트립 — EV 카드와 동일한 시각 단서 -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@drawable/ad_strip_ev" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="14dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ad_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/ad_logo_bg"
                    android:contentDescription="@null" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ad_headline"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/ad_text_primary"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/ad_body"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textSize="11sp"
                        android:textColor="@color/ad_text_secondary"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <!-- AD 라벨 — EV 카드 status chip 자리에 위치 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="@drawable/ad_label_bg"
                        android:paddingStart="7dp"
                        android:paddingEnd="7dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp">
                        <View
                            android:layout_width="5dp"
                            android:layout_height="5dp"
                            android:background="@drawable/ad_strip_ev"
                            android:layout_marginEnd="5dp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="광고"
                            android:textSize="10.5sp"
                            android:textStyle="bold"
                            android:textColor="@color/ad_label_text"
                            android:includeFontPadding="false" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/ad_call_to_action"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFFFF"
                    android:textAllCaps="false"
                    android:background="@drawable/ad_cta_bg"
                    android:stateListAnimator="@null" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
