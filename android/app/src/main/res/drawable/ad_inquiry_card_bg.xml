<?xml version="1.0" encoding="utf-8"?>
<!-- 1:1 문의 네이티브 광고 카드 — 그라데이션 테두리(파랑→청록) + 테마 대응 내부 카드 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 테두리: 그라데이션 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3B6DFF"
                android:centerColor="#2E9BE6"
                android:endColor="#22C6A0"
                android:angle="0" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <!-- 내부 카드: 테마 색(라이트=흰색 / 다크=#12141A) -->
    <item
        android:top="1.5dp"
        android:bottom="1.5dp"
        android:left="1.5dp"
        android:right="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/ad_card_bg" />
            <corners android:radius="16.5dp" />
        </shape>
    </item>
</layer-list>
