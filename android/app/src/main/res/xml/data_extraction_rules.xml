<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+): 데이터 추출 규칙
  - cloud-backup: Google Drive 자동 백업 (다른 폰에서 같은 계정으로 복원)
  - device-transfer: 폰-폰 직접 전송 (페어링)
-->
<data-extraction-rules>
  <cloud-backup>
    <!-- 동일한 exclude 규칙 (backup_rules.xml 과 일치) -->
    <exclude domain="sharedpref" path="com.google.firebase.iid.xml" />
    <exclude domain="sharedpref" path="com.google.android.gms.appid.xml" />
    <exclude domain="sharedpref" path="WidgetPrefs.xml" />
    <exclude domain="sharedpref" path="HomeWidgetPreferences.xml" />

    <exclude domain="file" path="splash_ad/" />
    <exclude domain="file" path="popup_ad/" />
    <exclude domain="file" path="house_ad/" />
    <exclude domain="file" path="libCachedImageData/" />
    <exclude domain="file" path="cached_network_images/" />
  </cloud-backup>

  <device-transfer>
    <!-- 폰-폰 전송에서도 같은 규칙 (FCM 토큰만 device-local 종속) -->
    <exclude domain="sharedpref" path="com.google.firebase.iid.xml" />
    <exclude domain="sharedpref" path="com.google.android.gms.appid.xml" />
    <exclude domain="sharedpref" path="WidgetPrefs.xml" />
    <exclude domain="sharedpref" path="HomeWidgetPreferences.xml" />
  </device-transfer>
</data-extraction-rules>
